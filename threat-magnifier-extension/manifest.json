{
  "manifest_version": 3,
  "name": "Threat Magnifier",
  "version": "1.0",
  "description": "Like a magnifying glass, point at web components to see if they are a potential threat.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": ["*://*.virustotal.com/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": [
        "scripts/api.js",
        "scripts/analyzer.js",
        "scripts/ui.js",
        "content.js"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "threatmagnifier@example.com",
      "strict_min_version": "109.0"
    }
  }
}
